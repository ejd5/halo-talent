{
  "manifest_version": 3,
  "name": "Halo Companion",
  "version": "1.0.0",
  "description": "Assistant IA pour créateurs de contenu",
  "permissions": ["sidePanel", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
